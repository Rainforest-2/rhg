+      break;
+    case 'bcuCatCannonRejected':
+    case 'bcuWalletUpgradeRejected':
+    case 'bcuSpiritSummonBlocked':
+      playBcuSetSe(scene, BCU_SE.SPEND_FAIL, engine);
