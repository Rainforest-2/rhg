
# Generated semantic bundles are runtime assets.
# Keep public/assets/bundles/core/core-db.zip trackable because GitHub Pages must serve it.
tmp/ui-polish-screens/
tmp/agent-scratch/
tmp/playwright-*/
tmp/character-modification-ui/
__probe*.mjs
scratch-*.sh
/playwright-report/
/test-results/

# Build/audit-only artifacts: regenerated by audit/build scripts and read only by
# standalone audit checks (never by the browser runtime or the committed
# verify suite). Keep them out of the deployed/tracked tree to shrink the deploy.
public/assets/generated/bcu-asset-audit.json
public/assets/generated/bcu-asset-audit.md
public/assets/generated/bcu-icon-source-audit.json
public/assets/generated/bcu-icon-source-audit.md
public/assets/generated/bcu-diagnostics.json
public/assets/generated/bcu-lang-prune-report.json
public/assets/generated/bcu-lang-prune-report.md
node_modules/
dist/

# Python bytecode (tools/extract_bcuzip.py and other helper scripts).
__pycache__/
*.pyc
