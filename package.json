{
  "name": "rhg-bcu-battle",
  "version": "1.0.0",
  "private": true,
  "description": "BCU-parity battle/stage/render web app bundled with Vite.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rainforest-2/rhg.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "playwright": "^1.60.0",
    "vite": "^8.1.0"
  },
  "scripts": {
    "agent:context": "node scripts/agent-context.mjs",
    "agent:changed": "node scripts/agent-changed.mjs",
    "agent:find": "node scripts/agent-find.mjs",
    "agent:checks": "node scripts/agent-checks.mjs",
    "agent:probe": "node scripts/agent-probe.mjs",
    "agent:run": "node scripts/agent-run.mjs",
    "capture:community-phase0": "node scripts/capture-community-stage-phase0-fixtures.mjs",
    "capture:community-phase0:screens": "node scripts/capture-community-stage-phase0-screenshots.mjs",
    "generate:bcu-stage-crowns": "node scripts/build-bcu-stage-crown-index.mjs",
    "precheck": "npm run generate:bcu-stage-crowns",
    "check": "node scripts/check-bcu-ability-parity-safe-suite.mjs && node scripts/check-open-issue-regressions.mjs && node scripts/check-custom-stage-schema-v3.mjs",
    "check:custom-stage-schema-v3": "node scripts/check-custom-stage-schema-v3.mjs",
    "check:character-modification": "node scripts/check-character-modification-schema.mjs && node scripts/check-character-modification-codec.mjs && node scripts/check-character-modification-resolver.mjs && node scripts/check-character-modification-derived-model.mjs && node scripts/check-character-modification-cache.mjs && node scripts/check-character-modification-production.mjs && node scripts/check-custom-stage-character-modification.mjs && node scripts/check-formation-character-modification.mjs && node scripts/check-character-modification-import-security.mjs && node scripts/check-character-modification-runtime-integration.mjs",
    "check:character-modification:ui": "node scripts/check-character-modification-ui.mjs",
    "test": "node --test tests/*.test.mjs",
    "verify": "npm run check && npm test",
    "verify:dev": "bash scripts/dev-verify-env.sh",
    "preview:stop": "bash scripts/stop-preview.sh",
    "predev": "npm run generate:bcu-stage-crowns",
    "dev": "vite",
    "prebuild": "npm run generate:bcu-stage-crowns",
    "build": "vite build",
    "preview": "vite preview"
  }
}
