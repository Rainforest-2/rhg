function mChangeTab(tabname) {
 document.getElementById('m_event').style.display = 'none';
 document.getElementById('m_lot').style.display = 'none';
 document.getElementById('m_mission').style.display = 'none';
 document.getElementById('m_sale').style.display = 'none';
 document.getElementById(tabname).style.display = 'block';
}
mChangeTab('m_event');<!--デフォルトタブ-->
</script>

